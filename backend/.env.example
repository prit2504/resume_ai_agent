# -------------------------------------------------------------
# LinkedIn Job Matcher Environment Variables
# -------------------------------------------------------------

# LLM Provider Configuration
# Choose one of: ollama, openai, gemini, huggingface
LLM_PROVIDER=huggingface
EMBEDDING_PROVIDER = ollama

# Provider-Specific API Keys (Only the chosen provider needs to be set)
OPENAI_API_KEY=your_openai_api_key_here
GEMINI_API_KEY=your_gemini_api_key_here
HF_TOKEN=

# Provider-Specific Model Selections
# E.g., for openai: gpt-4o, text-embedding-3-small
# E.g., for gemini: gemini-2.5-flash, text-embedding-004
# E.g., for huggingface: meta-llama/Llama-3-8b-instruct
ADVISOR_MODEL=google/gemma-3-12b-it:featherless-ai
EXTRACTOR_MODEL=google/gemma-3-4b-it:featherless-ai
EMBED_MODEL=nomic-embed-text:v1.5
EMBED_DIM=768

# If using Ollama or a custom OpenAI-compatible endpoint directly
# (These will be ignored if LLM_PROVIDER is set to gemini/openai/huggingface)
LLM_BASE_URL=http://localhost:11434/v1
EMBED_BASE_URL=http://localhost:11434/v1

# Qdrant Vector Database
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=
QDRANT_COLLECTION=linkedin_jobs

# LinkedIn MCP Server
MCP_LINKEDIN_URL=http://localhost:8080/mcp
